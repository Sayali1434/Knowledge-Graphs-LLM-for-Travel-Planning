// Creates temporary TRAVEL_TO relationships for this mini-KG only.
// Re-running the query replaces prior TRAVEL_TO edges for the same query_id.
WITH "idx_0" AS queryId
OPTIONAL MATCH ()-[old:TRAVEL_TO {mini_kg_query_id: queryId}]->()
DELETE old
WITH queryId, [
  {step_index: 1, source_element_id: "4:ac4766e1-4704-4660-9f0f-fb9a1b3a3651:13", target_element_id: "4:ac4766e1-4704-4660-9f0f-fb9a1b3a3651:18155", properties: {mini_kg_only: true, display_scope: "mini_kg_only", derived_from: "poi_list", query_id: "idx_0", day_number: 1, day_date: "2024-11-04", from_sequence: 1, to_sequence: 2, from_name: "Private Room & Bath! Steps to Restaurants & Shops", to_name: "Barbusa", from_label: "Accommodation", to_label: "Restaurant", from_time: "13:00", to_time: "13:30"}},
