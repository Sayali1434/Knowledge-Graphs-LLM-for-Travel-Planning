  {step_index: 5, source_element_id: "4:ac4766e1-4704-4660-9f0f-fb9a1b3a3651:13", target_element_id: "4:ac4766e1-4704-4660-9f0f-fb9a1b3a3651:13", properties: {mini_kg_only: true, display_scope: "mini_kg_only", derived_from: "poi_list", query_id: "idx_0", day_number: 1, day_date: "2024-11-04", from_sequence: 5, to_sequence: 1, from_name: "Private Room & Bath! Steps to Restaurants & Shops", to_name: "Private Room & Bath! Steps to Restaurants & Shops", from_label: "Accommodation", to_label: "Accommodation", from_time: "07:00", to_time: "07:15"}},
