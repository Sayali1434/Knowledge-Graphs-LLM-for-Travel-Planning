  {step_index: 14, source_element_id: "4:ac4766e1-4704-4660-9f0f-fb9a1b3a3651:18167", target_element_id: "4:ac4766e1-4704-4660-9f0f-fb9a1b3a3651:36", properties: {mini_kg_only: true, display_scope: "mini_kg_only", derived_from: "poi_list", query_id: "idx_0", day_number: 3, day_date: "2024-11-06", from_sequence: 2, to_sequence: 3, from_name: "Covewood Restaurant", to_name: "Birch Aquarium at Scripps", from_label: "Restaurant", to_label: "Attraction", from_time: "09:45", to_time: "10:00"}},
  {step_index: 15, source_element_id: "4:ac4766e1-4704-4660-9f0f-fb9a1b3a3651:36", target_element_id: "4:ac4766e1-4704-4660-9f0f-fb9a1b3a3651:18168", properties: {mini_kg_only: true, display_scope: "mini_kg_only", derived_from: "poi_list", query_id: "idx_0", day_number: 3, day_date: "2024-11-06", from_sequence: 3, to_sequence: 4, from_name: "Birch Aquarium at Scripps", to_name: "Ironside Fish & Oyster", from_label: "Attraction", to_label: "Restaurant", from_time: "14:15", to_time: "14:45"}},
  {step_index: 16, source_element_id: "4:ac4766e1-4704-4660-9f0f-fb9a1b3a3651:18168", target_element_id: "4:ac4766e1-4704-4660-9f0f-fb9a1b3a3651:28", properties: {mini_kg_only: true, display_scope: "mini_kg_only", derived_from: "poi_list", query_id: "idx_0", day_number: 3, day_date: "2024-11-06", from_sequence: 4, to_sequence: 5, from_name: "Ironside Fish & Oyster", to_name: "Little Italy", from_label: "Restaurant", to_label: "Attraction", from_time: "15:30", to_time: "16:00"}},
  {step_index: 17, source_element_id: "4:ac4766e1-4704-4660-9f0f-fb9a1b3a3651:28", target_element_id: "4:ac4766e1-4704-4660-9f0f-fb9a1b3a3651:18170", properties: {mini_kg_only: true, display_scope: "mini_kg_only", derived_from: "poi_list", query_id: "idx_0", day_number: 3, day_date: "2024-11-06", from_sequence: 5, to_sequence: 6, from_name: "Little Italy", to_name: "La Puerta", from_label: "Attraction", to_label: "Restaurant", from_time: "18:30", to_time: "21:00"}}
] AS travelToEdges
UNWIND travelToEdges AS travelEdge
MATCH (n) WHERE elementId(n) = travelEdge.source_element_id
MATCH (m) WHERE elementId(m) = travelEdge.target_element_id
CREATE (n)-[r:TRAVEL_TO]->(m)
SET r += travelEdge.properties,
    r.mini_kg_query_id = queryId,
    r.travel_step_index = travelEdge.step_index
RETURN n, r, m
ORDER BY r.travel_step_index
