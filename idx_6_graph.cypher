ng\", \"type\": \"Rapid Transit\"}, {\"id\": \"new-york-new-york-city-subway-3\", \"lineName\": \"3\", \"lineSymbol\": \"https://static.tacdn.com/img/api/metro_stations/metro_placeholder.png\", \"systemName\": \"NYC Subway\", \"systemSymbol\": \"https://static.tacdn.com/img/api/metro_stations/metro_placeholder.png\", \"type\": \"Rapid Transit\"}], \"latitude\": 40.73857116699219, \"longitude\": -73.99942016601562, \"distance\": 0.4663940218956756}, {\"name\": \"Christopher St \\u2013 Sheridan Square\", \"localName\": \"Christopher St \\u2013 Sheridan Square\", \"address\": \"97 7th Ave S, New York City, NY 10014\", \"localAddress\": \"97 7th Ave S, 10014\", \"lines\": [{\"id\": \"new-york-new-york-city-subway-1\", \"lineName\": \"1\", \"lineSymbol\": \"https://static.tacdn.com/img/api/metro_stations/metro_placeholder.png\", \"systemName\": \"NYC Subway\", \"systemSymbol\": \"https://static.tacdn.com/img/api/metro_stations/metro_placeholder.png\", \"type\": \"Rapid Transit\"}, {\"id\": \"new-york-new-york-city-subway-2\", \"lineName\": \"2\", \"lineSymbol\": \"https://static.tacdn.com/img/api/metro_stations/metro_placeholder.png\", \"systemName\": \"NYC Subway\", \"systemSymbol\": \"https://static.tacdn.com/img/api/metro_stations/metro_placeholder.png\", \"type\": \"Rapid Transit\"}], \"latitude\": 40.73342514038086, \"longitude\": -74.0029067993164, \"distance\": 0.5111858304480532}, {\"name\": \"18th St\", \"localName\": \"18th St\", \"address\": \"126 7th Ave, Hoboken, NJ 10011\", \"localAddress\": \"126 7th Ave, 10011\", \"lines\": [{\"id\": \"new-york-new-york-city-subway-1\", \"lineName\": \"1\", \"lineSymbol\": \"https://static.tacdn.com/img/api/metro_stations/metro_placeholder.png\", \"systemName\": \"NYC Subway\", \"systemSymbol\": \"https://static.tacdn.com/img/api/metro_stations/metro_placeholder.png\", \"type\": \"Rapid Transit\"}, {\"id\": \"new-york-new-york-city-subway-2\", \"lineName\": \"2\", \"lineSymbol\": \"https://static.tacdn.com/img/api/metro_s