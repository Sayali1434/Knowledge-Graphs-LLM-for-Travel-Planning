egan options", "Gluten free options"], id: "422496.0", longitude: "-70.55823", image: "https://media-cdn.tripadvisor.com/media/photo-s/02/62/09/33/french-toast.jpg", isLongClosed: "False", `Rest-Inexpensive`: "20.0", `Range.1`: "55.00 - 100.00", rankingString: "#4 of 38 Restaurants in Oak Bluffs", openNowText: "Open Now", City: "Martha's Vineyard", mealTypes: ["Breakfast", "Lunch", "Brunch"], Range: "15.00 - 31.00", cuisines: ["American"], localName: "Linda Jean's Restaurant", input: "Martha's Vineyard", phone: "+1 508-693-4093", State: "Massachusetts", webUrl: "https://www.tripadvisor.com/Restaurant_Review-g41750-d422496-Reviews-Linda_Jean_s_Restaurant-Oak_Bluffs_Martha_s_Vineyard_Massachusetts.html", localAddress: "25 Circuit Ave, 02557", `Rest-MidRange`: "60.0", name: "Linda Jean's Restaurant", subcategories: ["Sit down"], rawRanking: "4.297261714935303", orderOnline: [], establishmentTypes: ["Restaurants"], isClaimedIcon: "True", latitude: "41.45625", menuWebUrl: "https://lindajeansrestaurantmv.com/menus/", description: "Located in the heart of Oak Bluffs on Circuit Ave., Linda Jean’s is a sit-down restaurant (with take out) that has been a staple of the Vineyard community for almost 50 years. Husband and wife team, Lisa and Winston Christie took over the restaurant in 2023 when the previous own retired after 47 years of ownership. An Island favorite among both locals and visitors, Linda Jean’s serves Breakfast, Lunch and Dinner along with a with a full bar of beverages and cocktails and our bottomless coffee. Our goal is to provide great food at reasonable prices, including the comfort food that you love and remember along with some of Winston’s favorites added to the menu. We’re excited for you to come in and enjoy a home cooked meal at Linda Jean’s. We offer Breakfast and Lunch Daily and Dinner is offered Thursday - Monday.", photoCount: "119.0", ratingHistogram: "{\"count1\": 22, \"count2\": 23, \"count3\": 83, \"count4\": 271, \"count5\": 502}", email: "lindajeansmv@yahoo.com", website: "http://www.lindajeansrestaurant.com", rankingPosition: "4.0", hours: "{\"weekRanges\": [[{\"open\": 420, \"openHours\": \"07:00\", \"close\": 840, \"closeHours\": \"14:00\"}], [{\"open\": 420, \"openHours\": \"07:00\", \"close\": 900, \"closeHours\": \"15:00\"}], [{\"open\": 420, \"openHours\": \"07:00\", \"close\": 900, \"closeHours\": \"15:00\"}], [{\"open\": 420, \"openHours\": \"07:00\", \"close\": 900, \"closeHours\": \"15:00\"}], [{\"open\": 420, \"openHours\": \"07:00\", \"close\": 900, \"closeHours\": \"15:00\"}], [{\"open\": 420, \"openHours\": \"07:00\", \"close\": 900, \"closeHours\": \"15:00\"}], [{\"open\": 420, \"openHours\": \"07:00\", \"close\": 840, \"closeHours\": \"14:00\"}]], \"timezone\": \"America/New_York\"}", address: "25 Circuit Ave, Oak Bluffs, Martha's Vineyard, MA 02557", neighborhoodLocations: [], dishes: ["Chowder", "Cheeseburger", "Crab", "Fish & Chips", "French Toast", "Burger", "Lobster", "Lobster Roll", "Omelette", "Shrimp", "Salad", "Pancakes", "Clam Chowder", "Eggs Benedict", "Grilled cheese", "Waffles", "Fish Sandwich", "Scallops", "Haddock", "Tuna", "Clams", "Toasts", "Beef", "Cakes", "Fish", "Poached Eggs", "Home Fries", "Onion Rings", "Scrambled Eggs", "Sausage", "Blueberry Pancakes", "Fried", "Hash", "Mashed Potatoes"], reviewTags: "[{\"text\": \"pancakes\", \"reviews\": 59}, {\"text\": \"home fries\", \"reviews\": 26}, {\"text\": \"sandwich\", \"reviews\": 20}, {\"text\": \"martha's vineyard\", \"reviews\": 63}, {\"text\": \"day trip\", \"reviews\": 11}, {\"text\": \"text\", \"reviews\": 19}, {\"text\": \"egg\", \"reviews\": 13}, {\"text\": \"mv\", \"reviews\": 46}, {\"text\": \"ferry\", \"reviews\": 29}]", isClosed: "False", isNearbyResult: "False", `S.No.`: "45", rankingDenominator: "38.0", locationString: "Oak Bluffs, Martha's Vineyard, Massachusetts", category: "restaurant", ancestorLocations: "[{\"id\": \"41750\", \"name\": \"Oak Bluffs\", \"abbreviation\": null, \"subcategory\": \"City\"