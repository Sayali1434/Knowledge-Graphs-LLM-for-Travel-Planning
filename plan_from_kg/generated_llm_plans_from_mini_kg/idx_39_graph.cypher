SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "23875", latitude: "33.76342", rating: "4.5", description: "Georgia Aquarium contains more than 70 amazing habitats, with thousands of marine animals such as whale sharks, manta rays, beluga whales, and more. Don’t miss out on the animal encounter programs, where you can get up close and personal with dolphins, penguins, and sea lions. Combine your visit to the aquarium with other top attractions and enjoy additional discounts with the Atlanta CityPASS. You might also want to visit around Halloween or the holidays for special themed activities or presentations. – Tripadvisor", visit_duration: "3.5", addressObj: "{\"street1\": \"225 Baker St\", \"street2\": \"\", \"city\": \"Atlanta\", \"state\": \"GA\", \"country\": \"United States\", \"postalcode\": \"30313-1809\"}", offerGroup: "{\"lowestPrice\": \"$18.00\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FAtlanta%2FAtlanta-CityPass%2Fd784-2640ATL%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=3ae0eb16017937810&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=588792&clt=TD&from=api&nt=true\", \"price\": \"$102.25\", \"roundedUpPrice\": \"$103\", \"offerType\": null, \"title\": \"Atlanta CityPASS\\u00ae\", \"productCode\": \"2640ATL\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/0b/e6/ab/be.jpg\", \"description\": null, \"primaryCategory\": \"Sightseeing Passes\"}, {\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FAtlanta%2FAtlanta-Downtown-Tour%2Fd784-169395P1%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=aafc7b020d93ca03b&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=2&cnt=1&geo=588792&clt=TD&from=api&nt=true\", \"price\": \"$89.99\", \"roundedUpPrice\": \"$90\", \"offerTy