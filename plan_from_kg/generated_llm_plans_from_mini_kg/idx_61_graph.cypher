y-sourced, seasonal ingredients to create delectable and memorable dishes. Zocca’s private dining options can accommodate from 10 guests to 100, in an al fresco patio setting to the convivial Chef’s Table to buy-out of the entire restaurant.", photoCount: "360.0", ratingHistogram: "{\"count1\": 51, \"count2\": 56, \"count3\": 165, \"count4\": 388, \"count5\": 1250}", website: "http://www.zoccariverwalk.com", rankingPosition: "27.0", hours: "{\"weekRanges\": [[{\"open\": 420, \"openHours\": \"07:00\", \"close\": 900, \"closeHours\": \"15:00\"}, {\"open\": 1020, \"openHours\": \"17:00\", \"close\": 1320, \"closeHours\": \"22:00\"}], [{\"open\": 360, \"openHours\": \"06:00\", \"close\": 840, \"closeHours\": \"14:00\"}, {\"open\": 1020, \"openHours\": \"17:00\", \"close\": 1320, \"closeHours\": \"22:00\"}], [{\"open\": 360, \"openHours\": \"06:00\", \"close\": 840, \"closeHours\": \"14:00\"}, {\"open\": 1020, \"openHours\": \"17:00\", \"close\": 1320, \"closeHours\": \"22:00\"}], [{\"open\": 360, \"openHours\": \"06:00\", \"close\": 840, \"closeHours\": \"14:00\"}, {\"open\": 1020, \"openHours\": \"17:00\", \"close\": 1320, \"closeHours\": \"22:00\"}], [{\"open\": 360, \"openHours\": \"06:00\", \"close\": 840, \"closeHours\": \"14:00\"}, {\"open\": 1020, \"openHours\": \"17:00\", \"close\": 1320, \"closeHours\": \"22:00\"}], [{\"open\": 360, \"openHours\": \"06:00\", \"close\": 840, \"closeHours\": \"14:00\"}, {\"open\": 1020, \"openHours\": \"17:00\", \"close\": 1320, \"closeHours\": \"22:00\"}], [{\"open\": 420, \"openHours\": \"07:00\", \"close\": 900, \"closeHours\": \"15:00\"}, {\"open\": 1020, \"openHours\": \"17:00\", \"close\": 1320, \"closeHours\": \"22:00\"}]], \"timezone\": \"America/Chicago\"}", address: "420 W Market St On the Riverwalk, San Antonio, TX 78205-2920", neighborhoodLocations: "[{\"id\": \"21002007\", \"name\": \"Downtown\"}]", dishes: ["Pasta", "Cheesecake", "Crab", "Lasagne", "Lobster", "Omelette", "Polenta", "Ribs", "Shrimp", "Salad", "Calamari", "Alfredo", "Risotto", "Tiramisu", "Meatballs", "Tagliatelle", "Bolognese", "Scallops", "Salmon", "Beef", "Antipasti", "Pesto", "Cakes", "Soup", "Rigatoni", "Veal", "Sausage", "Cake", "Pappardelle", "Beet Salad"], reviewTags: "[{\"text\": \"pasta\", \"reviews\": 147}, {\"text\": \"tiramisu\", \"reviews\": 44}, {\"text\": \"westin hotel\", \"reviews\": 112}, {\"text\": \"the river\", \"reviews\": 176}, {\"text\": \"our waiter\", \"reviews\": 159}, {\"text\": \"dining experience\", \"reviews\": 43}, {\"text\": \"an appetizer\", \"reviews\": 28}, {\"text\": \"riverwalk\", \"reviews\": 505}, {\"text\": \"entrees\", \"reviews\": 84}, {\"text\": \"downtown\", \"reviews\": 21}, {\"text\": \"texas\", \"reviews\": 19}]", isClosed: "False", isNearbyResult: "False", `S.No.`: "59", rankingDenominator: "4547.0", locationString: "San Antonio, Texas", category: "restaurant", ancestorLocations: "[{\"id\": \"60956\", \"name\": \"San Antonio\", \"abbreviation\": null, \"subcategory\": \"City\"}, {\"id\": \"28964\", \"name\": \"Texas\", \"abbreviation\": \"TX\", \"subcategory\": \"State\"}, {\"id\": \"191\", \"name\": \"United States\", \"abbreviation\": null, \"subcategory\": \"Country\"}]", node_key: "Restaurant::1238474.0", source_kind: "mini_kg" };
