SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "1928", latitude: "29.460735", rating: "4.5", description: "Originally a rock quarry, part of the tea garden came from a donation by George W. Brackenridge and another section from Emma Koehler. In 1915 Ray Lambert, city parks commissioner, thought it would make a nice location for a lily pond. Ultimately, it grew to become a tea garden. The latest renovations began in 2007 and cost about $1.6 million, compared with the $7,000 Lambert originally spent to open the park. It is a Registered Texas Historic Landmark and on the National Register of Historic Places.", visit_duration: "4.5", addressObj: "{\"street1\": \"3853 N St. Mary_s St\", \"street2\": \"Brackenridge Park\", \"city\": \"San Antonio\", \"state\": \"TX\", \"country\": \"United States\", \"postalcode\": \"78212-3170\"}", offerGroup: "{\"lowestPrice\": \"$0.22\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FSan-Antonio%2FHalf-Day-San-Antonio-Evening-Grand-Historic-Tour%2Fd910-17570P5%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=98f280ae1aa317482&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=108031&clt=TD&from=api&nt=true\", \"price\": \"$75.00\", \"roundedUpPrice\": \"$75\", \"offerType\": null, \"title\": \"Half-Day Afternoon City Tour of Historic San Antonio \", \"productCode\": \"17570P5\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/06/dd/dd/a1.jpg\", \"description\": null, \"primaryCategory\": \"Half-day Tours\"}, {\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FSan-Antonio%2FFull-Day-San-Antonio-Grand-Historic-City-Tour-with-Lunch-Included%2Fd910-17570P7%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=efac52551bb6f4faf&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator