nic-San-Antonio-Night-Tour%2Fd910-87115P14%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=8aee11cacaf23ae31&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=5&cnt=1&geo=105056&clt=TD&from=api&nt=true\", \"price\": \"$129.00\", \"roundedUpPrice\": \"$129\", \"offerType\": null, \"title\": \"Scenic San Antonio Small Group Night Tour w/Riverwalk Boat Cruise\", \"productCode\": \"87115P14\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/0c/0a/15/f0.jpg\", \"description\": null, \"primaryCategory\": \"Cultural Tours\"}]}", subtype: ["Scenic Walking Areas"], ratingHistogram: "{\"count1\": 152, \"count2\": 342, \"count3\": 1814, \"count4\": 6628, \"count5\": 18151}", location_contains_city: "True", id: "105056", longitude: "-98.488785", website: "https://www.visitsanantonio.com/river-walk/", rankingPosition: "1.0", address: "849 E Commerce St, San Antonio, TX 78205-3939", neighborhoodLocations: "[{\"id\": \"21002007\", \"name\": \"Downtown\"}]", rankingString: "#1 of 590 things to do in San Antonio", City: "San Antonio", localName: "San Antonio River Walk", State: "Texas", webUrl: "https://www.tripadvisor.com/Attraction_Review-g60956-d105056-Reviews-San_Antonio_River_Walk-San_Antonio_Texas.html", localAddress: "849 E Commerce St, 78205-3939", rankingDenominator: "590.0", name: "San Antonio River Walk", locationString: "San Antonio, Texas", subcategories: ["Sights & Landmarks"], rawRanking: "5.0", node_key: "Attraction::105056", source_kind: "mini_kg" };
