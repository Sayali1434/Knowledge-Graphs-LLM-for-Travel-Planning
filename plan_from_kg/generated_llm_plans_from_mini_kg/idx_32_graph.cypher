SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "13798", latitude: "32.850586", rating: "4.5", description: "At this beach surronded by sandstone cliffs on the San Diego coast, the water is calm enough for travelers to enjoy diving and snorkeling. Walk along the rocky shore to spot large colonies of sea lions lounging in their natural habitat and looking after their pups, and have a picnic while soaking up the views of the ocean from the cliffs at sunset. If you visit at low tide, you’ll get to swim in the crystal clear tidal pools as well. You can also visit Sunny Jim's Sea Cave which is accessible via a tunnel. Visit early in the morning to find a parking space more easily. – Tripadvisor", visit_duration: "4.25", addressObj: "{\"street1\": \"1100 Coast Blvd\", \"street2\": null, \"city\": \"La Jolla\", \"state\": \"CA\", \"country\": \"United States\", \"postalcode\": \"92037-3600\"}", offerGroup: "{\"lowestPrice\": \"$9.99\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FSan-Diego%2FLa-Jolla-Tour%2Fd736-5044LJTOUR%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=a18fa92ba0217d588&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=255307&clt=TD&from=api&nt=true\", \"price\": \"$129.00\", \"roundedUpPrice\": \"$129\", \"offerType\": null, \"title\": \"The La Jolla Tour\", \"productCode\": \"5044LJTOUR\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/07/8e/aa/bd.jpg\", \"description\": null, \"primaryCategory\": \"City Tours\"}, {\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FSan-Diego%2FSan-Diego-Scenic-Tour%2Fd736-22921P1%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=229c8b633e9a15b22&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=2&cnt=1&geo=255307&clt=TD&from=api&nt=true