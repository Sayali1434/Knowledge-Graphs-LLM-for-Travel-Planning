SET n += { nearestMetroStations: "[{\"name\": \"Santa Fe Depot\", \"localName\": \"Santa Fe Depot\", \"address\": \"San Diego, CA\", \"localAddress\": \"\", \"lines\": [], \"latitude\": 32.716732025146484, \"longitude\": -117.1695785522461, \"distance\": 0.3764020826794977}]", localLangCode: "en-US", numberOfReviews: "25777", latitude: "32.71386", rating: "5.0", description: "Located in downtown San Diego, the USS Midway (Museum) was America’s longest-serving aircraft carrier of the 20th century. Today, the interactive museum is an unforgettable adventure for the entire family as guests walk in the footsteps of the 225,000 young men who served on Midway. Visitors explore a floating city at sea, the amazing flight deck and its 29 restored aircraft, flight simulators, and are inspired in the Battle of Midway Theater, included with admission. Admission also includes a self-guided audio tour narrated by Midway sailors in English, Mandarin, Spanish, Japanese, French and German. Visiting Midway is a once-in-a-lifetime experience in San Diego, known around the world as \"Navy Town, USA.\"", visit_duration: "3.0", addressObj: "{\"street1\": \"910 N Harbor Drive\", \"street2\": \"\", \"city\": \"San Diego\", \"state\": \"CA\", \"country\": \"United States\", \"postalcode\": \"92101-5811\"}", offerGroup: "{\"lowestPrice\": \"$5.00\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FSan-Diego%2FUSS-Midway-Museum%2Fd736-5160USS%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=cafbb3ed2c79be9aa&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=531819&clt=TD&from=api&nt=true\", \"price\": \"$32.00\", \"roundedUpPrice\": \"$32\", \"offerType\": null, \"title\": \"Skip the Line: USS Midway Museum Admission Ticket in San Diego\", \"productCode\": \"5160USS\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/07/ab/3d/2