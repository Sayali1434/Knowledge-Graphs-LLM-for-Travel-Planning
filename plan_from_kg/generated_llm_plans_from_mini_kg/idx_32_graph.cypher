SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "29995", latitude: "32.735275", rating: "4.5", description: "The San Diego Zoo pioneered cageless exhibits and offers travelers a fun and informative experience. Featuring over 4000 animals, the park gives you a peek into the wildlife of several ecosystems, from deserts to rainforests. Ride the tour bus, which crosses three quarters of the zoo’s area, and learn more about the animals from the guide as you view them in their natural habitats. You can also hop on the Skyfari gondola lift to see the entire park from above. Tickets to the San Diego Zoo that also cover the San Diego Zoo Safari Park in Escondido are available for a discount. – Tripadvisor", visit_duration: "3.6666666666666665", addressObj: "{\"street1\": \"2929 Zoo Drive\", \"street2\": \"Balboa Park\", \"city\": \"San Diego\", \"state\": \"CA\", \"country\": \"United States\", \"postalcode\": \"92101\"}", offerGroup: "{\"lowestPrice\": \"$19.99\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FSan-Diego%2FSan-Diego-Zoo%2Fd736-3097ZOO_TR%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=ca527f6b16a511f1f&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=104122&clt=TD&from=api&nt=true\", \"price\": \"$74.00\", \"roundedUpPrice\": \"$74\", \"offerType\": null, \"title\": \"San Diego Zoo 1-Day Pass: Any Day Ticket\", \"productCode\": \"3097ZOO_TR\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/13/8d/73/09.jpg\", \"description\": null, \"primaryCategory\": \"Zoo Tickets & Passes\"}, {\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FSan-Diego%2FSan-Diego-Zoo-and-Safari-Park-Combo-Tour%2Fd736-3097SDZSP_2VISIT%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=7347382584b381119&logme=true&uidparam=refid&attrc