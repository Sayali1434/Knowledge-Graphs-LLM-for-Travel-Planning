SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "371", latitude: "39.52105", rating: "4.5", description: "The Nevada Museum of Art is a museum of ideas. The only accredited art museum in the state, it is a private, non-profit organization supported by the generosity of its membership as well as by sponsorships and grants. Through creative programming and scholarship, the Museum provides the opportunity for people to encounter, engage and enjoy a diversity of art experiences. The Museum is open Wednesday through Sunday, 10 am to 6 pm, late on Thursdays until 8 pm. The galleries, Museum Store and on-site restaurant Chez Louie are closed on Mondays, Tuesdays and national holidays.", visit_duration: "3.0", addressObj: "{\"street1\": \"160 W Liberty St\", \"street2\": \"Prices\", \"city\": \"Reno\", \"state\": \"NV\", \"country\": \"United States\", \"postalcode\": \"89501-1916\"}", subtype: ["Art Museums"], ratingHistogram: "{\"count1\": 8, \"count2\": 12, \"count3\": 25, \"count4\": 90, \"count5\": 236}", location_contains_city: "True", id: "269519", longitude: "-119.81345", website: "http://www.nevadaart.org/", rankingPosition: "9.0", address: "160 W Liberty St Prices, Reno, NV 89501-1916", neighborhoodLocations: [], rankingString: "#9 of 201 things to do in Reno", City: "Reno", localName: "Nevada Museum of Art", State: "Nevada", webUrl: "https://www.tripadvisor.com/Attraction_Review-g45992-d269519-Reviews-Nevada_Museum_of_Art-Reno_Nevada.html", localAddress: "160 W Liberty St, Prices, 89501-1916", rankingDenominator: "201.0", name: "Nevada Museum of Art", locationString: "Reno, Nevada", subcategories: ["Museums"], rawRanking: "3.808694363", node_key: "Attraction::269519", source_kind: "mini_kg" };
