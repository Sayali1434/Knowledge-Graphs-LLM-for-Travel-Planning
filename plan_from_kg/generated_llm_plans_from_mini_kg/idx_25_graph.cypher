SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "1845", latitude: "39.526096", rating: "5.0", description: "The National Automobile Museum is one of the top Reno attractions with a “Wow!” factor you won't want to miss. Our Museum has more than 225 rare, one-of-a-kind, antique and collector cars with authentic street scenes and sounds that bring displays to life. With artifacts, a theatre presentation, audio tours, and a Museum Store – there’s lots to see and do. The Museum is located at 1 Museum Drive near Downtown Reno, on the banks of the Truckee River. There’s free parking in the Museum lot on Museum Drive off of Mill Street.", visit_duration: "3.0", addressObj: "{\"street1\": \"1 Museum Drive\", \"street2\": \"\", \"city\": \"Reno\", \"state\": \"NV\", \"country\": \"United States\", \"postalcode\": \"89501-1558\"}", subtype: ["Specialty Museums"], ratingHistogram: "{\"count1\": 3, \"count2\": 6, \"count3\": 36, \"count4\": 338, \"count5\": 1462}", location_contains_city: "True", id: "143008", longitude: "-119.80834", website: "http://www.automuseum.org/", rankingPosition: "2.0", address: "1 Museum Drive, Reno, NV 89501-1558", neighborhoodLocations: [], rankingString: "#2 of 201 things to do in Reno", City: "Reno", localName: "National Automobile Museum", State: "Nevada", webUrl: "https://www.tripadvisor.com/Attraction_Review-g45992-d143008-Reviews-National_Automobile_Museum-Reno_Nevada.html", localAddress: "1 Museum Drive, 89501-1558", rankingDenominator: "201.0", name: "National Automobile Museum", locationString: "Reno, Nevada", subcategories: ["Museums"], rawRanking: "4.226456642", node_key: "Attraction::143008", source_kind: "mini_kg" };
