SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "842", latitude: "35.051212", rating: "4.5", description: "Ready to get chilled while hearing some of the city's most fascinating history? Join us nightly (or weekends winter) at our haunted steampunk shop at 57 E 5th St (back side of the Taziki's building). Or for the truly adventurous, come on the ghost hunt to use some of our cutting edge equipment in some of the city's most haunted locations.", visit_duration: "3.0", addressObj: "{\"street1\": \"57 E 5th St\", \"street2\": \"\", \"city\": \"Chattanooga\", \"state\": \"TN\", \"country\": \"United States\", \"postalcode\": \"37402-1029\"}", offerGroup: "{\"lowestPrice\": \"$0.25\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FChattanooga%2FMurder-and-Mayhem-Haunted-History-Tour%2Fd27404-24909P3%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=ecb2a6bd9764a78a3&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=1739067&clt=TD&from=api&nt=true\", \"price\": \"$24.89\", \"roundedUpPrice\": \"$25\", \"offerType\": null, \"title\": \"Murder & Mayhem Haunted History Walking Tour\", \"productCode\": \"24909P3\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/0b/1f/ac/2f.jpg\", \"description\": null, \"primaryCategory\": \"Ghost & Vampire Tours\"}, {\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FChattanooga%2FCemetery-Ghost-Hunt-in-Chattanooga%2Fd27404-24909P2%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=0f2234a2778be1e6a&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=2&cnt=1&geo=1739067&clt=TD&from=api&nt=true\", \"price\": \"$33.95\", \"roundedUpPrice\": \"$34\", \"offerType\": null, \"title\": \"1.5-Hour Cemetery Ghost Hunt in Chattanooga\", \"productCode\": \"24909P2\", \"partne