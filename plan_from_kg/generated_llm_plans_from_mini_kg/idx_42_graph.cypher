SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "7113", latitude: "35.05586", rating: "4.5", description: "This aquarium has two buildings: River Journey, which showcases freshwater habitats from around the globe, and Ocean Journey, where travelers can view magnificent sea creatures. We recommend spending at least three hours at the aquarium as there are over 10,000 animals here. The little ones will especially love the cute macaroni penguins and mesmerizing sea jellies. Weekends are the busiest, so consider visiting on a weekday for a quieter and more intimate experience. There’s timed entry to the aquarium, so plan ahead when booking your tickets. And don’t forget to make use of the city’s free shuttle to get there. – Tripadvisor", visit_duration: "3.5", addressObj: "{\"street1\": \"1 Broad St\", \"street2\": null, \"city\": \"Chattanooga\", \"state\": \"TN\", \"country\": \"United States\", \"postalcode\": \"37402-1023\"}", offerGroup: "{\"lowestPrice\": \"$33.87\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FChattanooga%2FHorse-drawn-carriage-services%2Fd27404-190263P1%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=773f68999d4ad1de8&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=104477&clt=TD&from=api&nt=true\", \"price\": \"$100.00\", \"roundedUpPrice\": \"$100\", \"offerType\": null, \"title\": \"Private Chattanooga Horse & Carriage Tour\", \"productCode\": \"190263P1\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/09/0f/c7/8a.jpg\", \"description\": null, \"primaryCategory\": \"Historical & Heritage Tours\"}, {\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FChattanooga%2FHistoric-Downtown-Chattanooga-Segway-Tour%2Fd27404-42338P1%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=c9443eab643072