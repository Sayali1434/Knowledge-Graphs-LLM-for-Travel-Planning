SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "3979", latitude: "39.810604", rating: "4.5", description: "The largest children's museum in the world just got even bigger with the addition of a new 7.5-acre outdoor health and fitness area that encourages activity through multiple sports. The new space, called Riley Children's Health Sports Legends Experience includes basketball, football, hockey, soccer, pedal car racing (drag strip and oval track), golf, baseball, and tennis. The indoor portion of the new area includes the National Art Museum of Sport along with the World of Sport and History of Hoops. The Children's Museum of Indianapolis itself is made up of 500,000 square feet with exhibits and activities that are fun and interesting for the entire family as they explore the physical and natural sciences, history, world cultures and the arts through exciting interactive exhibits on five floors. Families will discover some of the most rare dinosaur fossils in the world and see what it's like to live and work in space. There's also a theater with children's plays and live entertainment.", visit_duration: "3.0", addressObj: "{\"street1\": \"3000 N Meridian St\", \"street2\": \"\", \"city\": \"Indianapolis\", \"state\": \"IN\", \"country\": \"United States\", \"postalcode\": \"46208-4716\"}", offerGroup: "{\"lowestPrice\": \"$0.75\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FIndiana%2F3-Day-Indy-Attraction-Pass%2Fd22216-319015P1%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=88745921ff63f5bcc&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=103671&clt=TD&from=api&nt=true\", \"price\": \"$75.00\", \"roundedUpPrice\": \"$75\", \"offerType\": null, \"title\": \"Indianapolis Attractions Pass\", \"productCode\": \"319015P1\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp