MERGE (n:Attraction {node_key: "Attraction::2619243"})
SET n += { nearestMetroStations: [], localLangCode: "es-CL", numberOfReviews: "283", latitude: "-33.029774", rating: "5.0", description: "CUSTOMIZED TOURS & PACKAGES IN CHILE : Atacama desert, Patagonia, Valparaiso, Wine country, Santiago, Easter Island & more... \"Travelling with Chile Private Tours is like visiting with friends\" This is what past travelers have told us, and we do our best to keep it that way. Hi, I'm Thomas Poussard, a French journalist and writer turned private guide in Chile, where I live since 2006. Along with my colleague Valentin, we create custom-made tours and itineraries throughout the entire country, from Patagonia to the Atacama desert, from Santiago to Easter Island, to the wine country, Valparaiso, the Lake District, the volcanoes and glaciers, etc. Our goal: to take into account all your requirements in order to create together the best possible program. Awarded the TripAdvisor Certificate of Excellence & Traveler's Choice for 6 straight years since 2015, we love to take our travelers off the beaten tracks, to show you our favorite places in each area of this beautiful country.", visit_duration: "3.1666666666666665", addressObj: "{\"street1\": null, \"street2\": null, \"city\": \"Vina del Mar\", \"state\": null, \"country\": \"Chile\", \"postalcode\": \"2570017\"}", subtype: ["City Tours", "Multi-day Tours", "Private Tours", "Nature & Wildlife Tours", "Wine Tours & Tastings"], ratingHistogram: "{\"count1\": 1, \"count2\": 0, \"count3\": 0, \"count4\": 4, \"count5\": 278}", location_contains_city: "True", id: "2619243", longitude: "-71.539116", website: "http://www.chileprivatetours.com", rankingPosition: "1.0", address: "Vina del Mar 2570017 Chile", neighborhoodLocations: [], rankingString: "#1 of 22 Tours in Vina del Mar", City: "Valparaiso", localName: "Chile Private Tours", State: "Indiana", webUrl: "https://www.tripadvisor.com/Attraction_Review-g295425-d2619243-Reviews-Chile_Private_Tours-Vina_del_Mar_Valparaiso_Region.html", rankingDenominator: "22.0", name: "Chile Private Tours", locationString: "Vina del Mar, Valparaiso Region", subcategories: ["Food & Drink", "Tours", "Outdoor Activities"], rawRanking: "4.406177998", node_key: "Attraction::2619243", source_kind: "mini_kg" };
