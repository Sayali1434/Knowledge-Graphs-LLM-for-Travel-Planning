SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "3352", latitude: "39.04495", rating: "5.0", description: "Drop in for an hour, come for lunch, or spend the entire day wandering through world-class galleries. The Nelson-Atkins Museum of Art is the cultural jewel of Kansas City and just three blocks from the Country Club Plaza, and admission is free. The Nelson-Atkins, recognized as one of America’s finest art museums, strives to be the place where the power of art engages the spirit of community. With 40,000 works of art, the Nelson-Atkins is best known for its new Bloch Galleries, featuring Impressionist and Post-Impressionist art, plus its Asian art, photography, American paintings, American Indian and Egyptian galleries. The Donald J. Hall Sculpture Park, a beautiful setting for a walk or picnic, is an oasis in the city and home to notable sculptures.", visit_duration: "3.0", addressObj: "{\"street1\": \"4525 Oak Street\", \"street2\": \"\", \"city\": \"Kansas City\", \"state\": \"MO\", \"country\": \"United States\", \"postalcode\": \"64111-1818\"}", offerGroup: "{\"lowestPrice\": \"$0.75\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FKansas-City%2FCue-and-Brew-Tour%2Fd22925-36761P2%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=cedabb656a7eb0a11&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=104332&clt=TD&from=api&nt=true\", \"price\": \"$76.93\", \"roundedUpPrice\": \"$77\", \"offerType\": null, \"title\": \"Cue and Brew Tour in Kansas City\", \"productCode\": \"36761P2\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/06/71/23/d1.jpg\", \"description\": null, \"primaryCategory\": \"Historical & Heritage Tours\"}, {\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FKansas-City%2FKansas-City-Segway-Tour-Country-Club-Plaza-Area%2Fd22925-6134P7%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=f0b3fce910042740d&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=2&cnt=1&geo=104332&clt=TD&from=api&nt=true\", \"price\": \"$75.00\", \"roundedUpPrice\": \"$75\", \"offerType\": null, \"title\": \"Kansas City Segway Tour: Art and Glide\", \"productCode\": \"6134P7\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/06/71/e2/4f.jpg\", \"description\": null, \"primaryCategory\": \"Segway Tours\"}, {\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FKansas-City%2FRomantic-tour-in-Kansas-City%2Fd22925-209615P78%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=9214a322ceb902183&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=3&cnt=1&geo=104332&clt=TD&from=api&nt=true\", \"price\": \"$178.15\", \"roundedUpPrice\": \"$179\", \"offerType\": null, \"title\": \"Art, Nature & Legacy: A Kansas City Private Walking Tour\", \"productCode\": \"209615P78\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/12/04/6f/d8.jpg\", \"description\": null, \"primaryCategory\": \"Cultural Tours\"}, {\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FKansas-City%2FThe-best-of-Kansas-City-walking-tour%2Fd22925-209615P77%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=4ae9b6a5053f6b178&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=4&cnt=1&geo=104332&clt=TD&from=api&nt=true\", \"price\": \"$193.45\", \"roundedUpPrice\": \"$194\", \"offerType\": null, \"title\": \"Kansas City Wander: From Plazas to Parks\", \"productCode\": \"209615P77\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/12/04/6c/43.jpg\", \"description\": null, \"primaryCategory\":