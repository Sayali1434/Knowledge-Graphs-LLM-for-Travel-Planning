SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "2608", latitude: "39.05168", rating: "4.5", description: "Opened as Royals Stadium on April 10, 1973, Kauffman is recognized throughout baseball as one of the game's most beautiful ballparks. Since then, many exciting games have been contested, including the 1973 and 2012 All-Star Games, three no-hitters, playoff games in 1976, '77, '78, '80, '81, '84, '85, 2014 and '15 with 13 World Series tilts in 1980, 1985, 2014 and 2015. The facility was officially renamed in honor of Ewing M. Kauffman in a ceremony at the stadium on July 2, 1993.", visit_duration: "3.0", addressObj: "{\"street1\": \"1 Royal Way\", \"street2\": null, \"city\": \"Kansas City\", \"state\": \"MO\", \"country\": \"United States\", \"postalcode\": \"64129-1695\"}", offerGroup: "{\"lowestPrice\": \"$0.25\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FKansas-City%2FBehind-the-scenes-tour-of-Kauffman-Stadium%2Fd22925-412375P1%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=176909783b08e6bc9&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=616534&clt=TD&from=api&nt=true\", \"price\": \"$25.00\", \"roundedUpPrice\": \"$25\", \"offerType\": null, \"title\": \"90 Minute Walking Tour in Kauffman Stadium\", \"productCode\": \"412375P1\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/11/91/99/d0.jpg\", \"description\": null, \"primaryCategory\": \"Historical & Heritage Tours\"}, {\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FKansas-City%2FKansas-City-Royals-Baseball-Game-Ticket-at-Kauffman-Stadium%2Fd22925-380793P17%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=b2b0c5d8a4780e203&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=2&cnt=1&geo=616534&clt=TD&from=api&nt=t