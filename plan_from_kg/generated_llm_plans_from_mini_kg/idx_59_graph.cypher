SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "454", latitude: "39.093292", rating: "5.0", description: "Drawing inspiration from the country's most corrupt political boss, Tom Pendergast, Tom's Town Distilling Co. is downtown Kansas City's first legal distillery since Prohibition. Enjoy a craft cocktail in our gorgeous art deco tasting room or take our 1 hour tour for an in-depth look at the distillation process and a brief overview of Kansas City during Boss Tom's rule. Cheers!", visit_duration: "2.5", addressObj: "{\"street1\": \"1701 Main St\", \"street2\": null, \"city\": \"Kansas City\", \"state\": \"MO\", \"country\": \"United States\", \"postalcode\": \"64108-1368\"}", offerGroup: "{\"lowestPrice\": \"$0.27\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FKansas-City%2FToms-Town-Distillery-Tour-and-Tasting%2Fd22925-113026P1%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=f0763d2fda0410b75&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=9756120&clt=TD&from=api&nt=true\", \"price\": \"$27.00\", \"roundedUpPrice\": \"$27\", \"offerType\": null, \"title\": \"Tom's Town Distillery Tour and Tasting\", \"productCode\": \"113026P1\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/07/19/f3/ad.jpg\", \"description\": null, \"primaryCategory\": \"Luxury Tours\"}, {\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FKansas-City%2FPendergast-Cocktail-College%2Fd22925-113026P2%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=3f6c1ce5ab8abca6e&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=2&cnt=1&geo=9756120&clt=TD&from=api&nt=true\", \"price\": \"$65.00\", \"roundedUpPrice\": \"$65\", \"offerType\": null, \"title\": \"Pendergast Cocktail College Classes\", \"productCode\": \"113026P