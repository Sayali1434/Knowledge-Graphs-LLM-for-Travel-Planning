SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "5682", latitude: "39.080673", rating: "5.0", description: "The National WWI Museum and Memorial is America's leading institution dedicated to remembering, interpreting and understanding the Great War and its enduring impact on the global community. The Museum and Memorial holds the most comprehensive collection of World War I objects and documents in the world and is the second-oldest public museum dedicated to preserving the objects, history and experiences of the war. The Museum and Memorial takes visitors of all ages on an epic journey through a transformative period and shares deeply personal stories of courage, honor, patriotism and sacrifice. Designated by Congress as America's official World War I Museum and Memorial and located in downtown Kansas City, Mo., the National WWI Museum and Memorial inspires thought, dialogue and learning to make the experiences of the Great War era meaningful and relevant for present and future generations.", visit_duration: "3.0", addressObj: "{\"street1\": \"2 Memorial Dr\", \"street2\": null, \"city\": \"Kansas City\", \"state\": \"MO\", \"country\": \"United States\", \"postalcode\": \"64108-4616\"}", offerGroup: "{\"lowestPrice\": \"$0.30\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FKansas-City%2FCue-and-Brew-Tour%2Fd22925-36761P2%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=cedabb656a7eb0a11&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=266888&clt=TD&from=api&nt=true\", \"price\": \"$76.93\", \"roundedUpPrice\": \"$77\", \"offerType\": null, \"title\": \"Cue and Brew Tour in Kansas City\", \"productCode\": \"36761P2\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/06/71/23/d1.jpg\", \"description\": null, \"primaryCategory\": \"Historical & Heritage Tours\"}, {\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FKansas-City%2FKansas-City-MO-Attractions-Pass%2Fd22925-364488P2%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=fabace7b45b5d9962&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=2&cnt=1&geo=266888&clt=TD&from=api&nt=true\", \"price\": \"$30.00\", \"roundedUpPrice\": \"$30\", \"offerType\": null, \"title\": \" Kansas City MO Attractions Pass\", \"productCode\": \"364488P2\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/12/84/3b/ba.jpg\", \"description\": null, \"primaryCategory\": \"Attraction Tickets\"}]}", subtype: ["Military Museums", "History Museums"], ratingHistogram: "{\"count1\": 5, \"count2\": 11, \"count3\": 62, \"count4\": 700, \"count5\": 4904}", location_contains_city: "True", id: "266888", longitude: "-94.58608", website: "http://www.theworldwar.org", rankingPosition: "3.0", address: "2 Memorial Dr, Kansas City, MO 64108-4616", neighborhoodLocations: "[{\"id\": \"21228893\", \"name\": \"Crown Center\"}]", rankingString: "#3 of 328 things to do in Kansas City", City: "Kansas City", localName: "National WWI Museum and Memorial", State: "Missouri", webUrl: "https://www.tripadvisor.com/Attraction_Review-g44535-d266888-Reviews-National_WWI_Museum_and_Memorial-Kansas_City_Missouri.html", localAddress: "2 Memorial Dr, 64108-4616", rankingDenominator: "328.0", name: "National WWI Museum and Memorial", locationString: "Kansas City, Missouri", subcategories: ["Museums"], rawRanking: "4.281483173", node_key: "Attraction::266888", source_kind: "mini_kg" };
