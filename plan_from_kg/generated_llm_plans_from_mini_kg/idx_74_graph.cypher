SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "1874", latitude: "27.94467", rating: "4.5", description: "This riverwalk is a scenic 2.6-mile-long path along the Hillsborough River where you can discover some of downtown Tampa’s must-sees. Enjoy a leisurely stroll and you'll pass by the Tampa Museum of Art, the Curtis Hixon Waterfront Park—perfect for a picnic overlooking the Tampa skyline—and finally the Tampa Bay History Center. You can also bike or take a scooter down the riverwalk. If you need a rest, there's no shortage of rest stops along the way to watch the water taxis sail by. You might even be inspired to take a boat tour on the river yourself! There are also plenty of restaurants and bars for food and drinks with a view. – Tripadvisor", visit_duration: "3.0", addressObj: "{\"street1\": null, \"street2\": null, \"city\": \"Tampa\", \"state\": \"FL\", \"country\": \"United States\", \"postalcode\": \"33602\"}", offerGroup: "{\"lowestPrice\": \"$8.99\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FTampa%2FPrivate-Photo-Session-with-a-Local-Photographer-in-Tampa%2Fd666-63511P824%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=87b7ad4a9fbd9e411&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=7317600&clt=TD&from=api&nt=true\", \"price\": \"$273.24\", \"roundedUpPrice\": \"$274\", \"offerType\": null, \"title\": \"Private Photo Session with a Local Photographer in Tampa\", \"productCode\": \"63511P824\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/07/b9/ca/ab.jpg\", \"description\": null, \"primaryCategory\": \"Photography Tours\"}, {\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FTampa%2FVacation-Photographer-in-Tampa%2Fd666-63511P525%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=41f7b8a8ff1