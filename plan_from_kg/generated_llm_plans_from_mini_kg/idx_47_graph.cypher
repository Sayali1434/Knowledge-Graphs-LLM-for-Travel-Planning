SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "1902", latitude: "39.04198", rating: "4.5", description: "Country Club Plaza is an open-air shopping and dining destination in the heart of Kansas City. Home to over 120 Shops & Eateries with a one-of-a-kind curated mix of national and local retailers & restaurants, over 50 unique to Kansas City. Known for its annual Plaza Art Fair and Holiday Lights, the Plaza’s design was inspired by Spanish architecture, boasts over 75 unique statues, fountains and one-of-a-kind artwork and has been a Kansas City tradition for over 100 years.", visit_duration: "1.5", addressObj: "{\"street1\": \"4706 Broadway Blvd\", \"street2\": null, \"city\": \"Kansas City\", \"state\": \"MO\", \"country\": \"United States\", \"postalcode\": \"64112-1934\"}", offerGroup: "{\"lowestPrice\": \"$0.49\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FKansas-City%2FCue-and-Brew-Tour%2Fd22925-36761P2%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=cedabb656a7eb0a11&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=104321&clt=TD&from=api&nt=true\", \"price\": \"$76.93\", \"roundedUpPrice\": \"$77\", \"offerType\": null, \"title\": \"Cue and Brew Tour in Kansas City\", \"productCode\": \"36761P2\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/06/71/23/d1.jpg\", \"description\": null, \"primaryCategory\": \"Historical & Heritage Tours\"}, {\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FKansas-City%2FPlaza-Lights-and-Crestwood-Urban-Hike%2Fd22925-138599P4%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=4682ff7e4a95aae0b&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=2&cnt=1&geo=104321&clt=TD&from=api&nt=true\", \"price\": \"$49.00\", \"roundedUpPrice\": \"$49\", \