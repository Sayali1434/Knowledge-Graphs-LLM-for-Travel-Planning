SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "1351", latitude: "38.05653", rating: "5.0", description: "Located in downtown Lexington, Kentucky. Join us for an intimate, educational and high caliber tour that includes the story of the historic Pepper Brand & Distillery, a tour of the working distillery and a tasting of our award-winning whiskeys. All tour guests receive a complimentary tasting glass and groups are limited in size for an optimal experience. Adults 21+ $20; Young Adult 14-20 $10; Veterans $10; Active Military Free Tour; restricted to age 14 and above. Please check in for your tour at least 10 minutes prior to the start time!", visit_duration: "2.5", addressObj: "{\"street1\": \"1228 Manchester St\", \"street2\": \"Suite 100\", \"city\": \"Lexington\", \"state\": \"KY\", \"country\": \"United States\", \"postalcode\": \"40504-1129\"}", offerGroup: "{\"lowestPrice\": \"$0.99\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FLexington%2FDistillery-District-Food-and-History-Tour%2Fd25316-349740P5%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=f50c79641070fb5f5&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=14792244&clt=TD&from=api&nt=true\", \"price\": \"$99.00\", \"roundedUpPrice\": \"$99\", \"offerType\": null, \"title\": \"Distillery District Food & History Tour in Lexington\", \"productCode\": \"349740P5\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/11/fa/1a/77.jpg\", \"description\": null, \"primaryCategory\": \"Historical & Heritage Tours\"}, {\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FLouisville%2FLexington-Bourbon-Tours-Large-Group-Pick-3-Woodford-and-More%2Fd25791-457466P8%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=c790c81f7836d96b9&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=2&cnt=1&geo=14792244&clt=TD&from=api&nt=true\", \"price\": \"$279.00\", \"roundedUpPrice\": \"$279\", \"offerType\": null, \"title\": \" Private Lexington Bourbon Tour (Groups of 7-13) Woodford & More \", \"productCode\": \"457466P8\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/12/7f/a3/32.jpg\", \"description\": null, \"primaryCategory\": \"Cultural Tours\"}, {\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FLouisville%2FLexington-Distillery-Tours-Woodford-Town-Branch-RD1-and-More%2Fd25791-457466P3%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=9ddb86b94264b3490&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=3&cnt=1&geo=14792244&clt=TD&from=api&nt=true\", \"price\": \"$459.00\", \"roundedUpPrice\": \"$459\", \"offerType\": null, \"title\": \"Private Lexington Bourbon Tour (Groups of 2-6) Woodford & More \", \"productCode\": \"457466P3\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/12/7d/25/c5.jpg\", \"description\": null, \"primaryCategory\": \"Cultural Tours\"}]}", subtype: ["Distilleries"], ratingHistogram: "{\"count1\": 0, \"count2\": 0, \"count3\": 7, \"count4\": 62, \"count5\": 1285}", location_contains_city: "True", id: "14792244", longitude: "-84.52015", website: "http://www.JamesEPepper.com", rankingPosition: "1.0", address: "1228 Manchester St Suite 100, Lexington, KY 40504-1129", neighborhoodLocations: [], rankingString: "#1 of 173 things to do in Lexington", City: "Lexington", localName: "James E. Pepper Distillery", State: "Kentucky", webUrl: "https://www.tripadvisor.com/Attraction_Review-g39588-d14792244-Reviews-James_E_Pepper_Distillery-Lexington_Kentucky.html", localAddress: "1228 Manchester St, Suite 100, 40504-1129", rankingDenominator: "173.0", name: "James E. Pepper Distillery", locationString: "Lexi