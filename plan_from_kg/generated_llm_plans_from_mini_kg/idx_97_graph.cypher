SET n += { nearestMetroStations: [], localLangCode: "en-US", address: "Lexington, KY", numberOfReviews: "1029", rating: "5.0", neighborhoodLocations: [], description: "Kentucky is renowned for its horse programs and farms, this is your chance to see the prestigious facilities up close. Tour area horse farms—some that are usually closed to the public—to get a look at the work that goes into raising and caring for thoroughbreds. The tour includes time to meet and interact with the horses, maybe even feed them their favorite peppermint treats.", City: "Lexington", addressObj: "{\"street1\": null, \"street2\": null, \"city\": \"Lexington\", \"state\": \"KY\", \"country\": \"United States\", \"postalcode\": null}", localName: "Unique Horse Farm Tours with Insider Access to Private Farms", subtype: [], State: "Kentucky", ratingHistogram: "{\"count1\": 4, \"count2\": 3, \"count3\": 11, \"count4\": 26, \"count5\": 724}", webUrl: "https://www.tripadvisor.com/AttractionProductReview-g39588-d13127245-Unique_Horse_Farm_Tours_with_Insider_Access_to_Private_Farms-Lexington_Kentucky.html", name: "Unique Horse Farm Tours with Insider Access to Private Farms", location_contains_city: "True", locationString: "Lexington, Kentucky", id: "13127245", subcategories: [], node_key: "Attraction::13127245", source_kind: "mini_kg" };
