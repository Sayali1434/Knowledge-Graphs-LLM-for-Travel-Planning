SET n += { nearestMetroStations: [], localLangCode: "en-US", address: "Lexington, KY", numberOfReviews: "1645", rating: "5.0", neighborhoodLocations: [], description: "Discover the heart and soul of Kentucky’s beautiful Bluegrass horse country on this guided, 3-hour, small-group tour. Get a behind-the-scenes look at the thoroughbred horse lifestyle as you explore the famous Keeneland Race Course and one or more thoroughbred horse farms. Learn about the history of racing and how Lexington became the epicenter of thoroughbred breeding in the United States. Note: itinerary may change depending on availability.", City: "Lexington", addressObj: "{\"street1\": null, \"street2\": null, \"city\": \"Lexington\", \"state\": \"KY\", \"country\": \"United States\", \"postalcode\": null}", localName: "Half-Day Thoroughbred Horse Farm Tour in Kentucky", subtype: [], State: "Kentucky", ratingHistogram: "{\"count1\": 0, \"count2\": 4, \"count3\": 11, \"count4\": 62, \"count5\": 1045}", webUrl: "https://www.tripadvisor.com/AttractionProductReview-g39588-d11467855-Half_Day_Thoroughbred_Horse_Farm_Tour_in_Kentucky-Lexington_Kentucky.html", name: "Half-Day Thoroughbred Horse Farm Tour in Kentucky", location_contains_city: "True", locationString: "Lexington, Kentucky", id: "11467855", subcategories: [], node_key: "Attraction::11467855", source_kind: "mini_kg" };
