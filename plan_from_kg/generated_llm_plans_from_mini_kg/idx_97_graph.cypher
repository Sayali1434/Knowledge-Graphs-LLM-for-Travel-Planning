SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "1019", latitude: "38.049885", rating: "4.5", description: "Beer & Bourbon Tours with Tastings: The first era of the Lexington Brewing Co. began in the 1890s and came to a halt during Prohibition, changing ownership several times in the decades that followed. By the time Pearse Lyons and his son, Mark, explored the brewery in 1999, it was a dilapidated shell of what it had once been. However, Pearse was a visionary and entrepreneur and saw only what it could be. Spurred by a passion for brewing and distilling that course through the Lyons family lineage of Irish coopers, Pearse revived Lexington Brewing Co. and restored a craft beer tradition that dates back to the 1700s. Pearse continued to dream big as he set his sights on distilling — a natural progression given his background in fermentation, his family’s heritage and Kentucky’s bourbon tradition. No time for a tour, come in for a pint or cocktail and enjoy the patio.", visit_duration: "2.75", addressObj: "{\"street1\": \"401 Cross St\", \"street2\": null, \"city\": \"Lexington\", \"state\": \"KY\", \"country\": \"United States\", \"postalcode\": \"40508-2806\"}", offerGroup: "{\"lowestPrice\": \"$0.27\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FLexington%2FLoco-in-Lexington%2Fd25316-200006P217%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=8dfb88b82993f2052&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=1657487&clt=TD&from=api&nt=true\", \"price\": \"$27.00\", \"roundedUpPrice\": \"$27\", \"offerType\": null, \"title\": \"Loco in Lexington, KY Scavenger Hunt\", \"productCode\": \"200006P217\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/0f/0b/07/3e.jpg\", \"description\": null, \"primaryCategory\": \"Self-guided Tours & Rentals\"}, {\"url\": \"https://