SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "1231", latitude: "32.071", rating: "5.0", description: "The third oldest Jewish congregation and the only neo-gothic Jewish sanctuary in the U. S. We host services every Friday & Saturday Shabbat and Jewish holidays. See our website for calendar of events. We offer tours Mon - Fri at 10am, 11am, 1:30pm & 2:30pm (except holidays) that include our historic sanctuary and museum with many historic artifacts including two Torahs written in the 1400's (probably the oldest in the U.S.).", visit_duration: "3.0", addressObj: "{\"street1\": \"20 E Gordon St\", \"street2\": null, \"city\": \"Savannah\", \"state\": \"GA\", \"country\": \"United States\", \"postalcode\": \"31401\"}", offerGroup: "{\"lowestPrice\": \"$0.30\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FSavannah%2FTrivia-Tour-1100am%2Fd5166-152349P2%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=f15ae14c8cab29e11&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=1117705&clt=TD&from=api&nt=true\", \"price\": \"$30.00\", \"roundedUpPrice\": \"$30\", \"offerType\": null, \"title\": \"Trivia Tour\", \"productCode\": \"152349P2\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/09/2e/9c/ce.jpg\", \"description\": null, \"primaryCategory\": \"Historical & Heritage Tours\"}, {\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FSavannah%2FThe-Wandering-Historians-of-Savannah-Historic-District-Tour%2Fd5166-16640P14%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=7fe75b09983608f10&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=2&cnt=1&geo=1117705&clt=TD&from=api&nt=true\", \"price\": \"$36.50\", \"roundedUpPrice\": \"$37\", \"offerType\": null, \"title\": \"Savannah Historic District Tour