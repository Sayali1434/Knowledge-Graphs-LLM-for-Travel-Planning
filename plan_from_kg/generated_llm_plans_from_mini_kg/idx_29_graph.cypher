SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "5396", latitude: "35.096313", rating: "4.0", description: "Founded in 1706 by Spanish Settlers, Old Town Albuquerque is a historical site in the city of Albuquerque. Built in a traditional Spanish colonial way, its quaint Plaza is anchored by the San Felipe de Neri Church. Today, the historic homes and buildings have been renovated into shops, art galleries, and cafes. You can stroll the district’s streets to discover stunning hidden patios and visit both the impressive Rattlesnake Museum and the history-laden Albuquerque Museum. Don't miss the Portal Market where local artisans sell handmade jewelry too. Join a food, historic, or ghost tour to dive into the city’s rich culture. – Tripadvisor", visit_duration: "2.5", addressObj: "{\"street1\": \"N Plaza St NW\", \"street2\": null, \"city\": \"Albuquerque\", \"state\": \"NM\", \"country\": \"United States\", \"postalcode\": \"87104\"}", offerGroup: "{\"lowestPrice\": \"$10.79\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FAlbuquerque%2F12pm-High-Noon-History-Legends-and-Lore-Guided-Old-Town-Stroll%2Fd28131-116027P3%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=a53b85d1602694668&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=144329&clt=TD&from=api&nt=true\", \"price\": \"$34.55\", \"roundedUpPrice\": \"$35\", \"offerType\": null, \"title\": \"12pm - Public High Noon History, Legends & Lore Tour - Guided Old Town Stroll\", \"productCode\": \"116027P3\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/12/f8/d6/f4.jpg\", \"description\": null, \"primaryCategory\": \"Cultural Tours\"}, {\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FAlbuquerque%2FThe-Ghost-Tour-of-Old-Town-Albuquerques-Ghost-Walk-since-2001%2Fd28131-116027P2