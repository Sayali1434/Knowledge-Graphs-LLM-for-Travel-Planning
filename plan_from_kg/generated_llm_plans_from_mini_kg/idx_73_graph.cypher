SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "13099", latitude: "32.731518", rating: "4.5", description: "This 1,200-acre nature park comprises 17 museums, gardens, musical theaters, a sports complex, and the world-famous San Diego Zoo. The park’s Spanish-Moorish architecture and 19 distinct gardens (some require admission fees) attract both tourists and locals. Don’t miss the San Diego Air and Space Museum, the Spanish Village Art Center for unique handicrafts, and the Spreckels Organ Pavilion, where free concerts are hosted in the evenings. Travelers recommend putting aside the whole day to explore the park. To make the most of your time, hop on the Balboa Park trams (they’re free!) to get around. – Tripadvisor", visit_duration: "3.0", addressObj: "{\"street1\": \"1549 El Prado\", \"street2\": \"\", \"city\": \"San Diego\", \"state\": \"CA\", \"country\": \"United States\", \"postalcode\": \"92101-1660\"}", offerGroup: "{\"lowestPrice\": \"$5.00\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FSan-Diego%2FSan-Diego-City-Lights-Night-Tour%2Fd736-5046SDNIGHT%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=9ea412f3ae694a030&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=102782&clt=TD&from=api&nt=true\", \"price\": \"$46.00\", \"roundedUpPrice\": \"$46\", \"offerType\": null, \"title\": \"San Diego After Dark: Explore the City's Nighttime Charms\", \"productCode\": \"5046SDNIGHT\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/09/17/3f/8f.jpg\", \"description\": null, \"primaryCategory\": \"Night Tours\"}, {\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FSan-Diego%2FSan-Diego-Tour-Hop-on-Hop-off-Trolley%2Fd736-5046SAN_OTT%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=b3f608dbd401132ff&logme=true&ui