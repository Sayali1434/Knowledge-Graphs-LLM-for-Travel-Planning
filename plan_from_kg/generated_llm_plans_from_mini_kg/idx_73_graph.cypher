iego%2FGPS-Talking-GoCar-2HR-Tour-Downtown-and-Balboa%2Fd736-3871P10%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=e5102e451712d5879&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=5&cnt=1&geo=104122&clt=TD&from=api&nt=true\", \"price\": \"$86.46\", \"roundedUpPrice\": \"$87\", \"offerType\": null, \"title\": \"2-Hour GoCar Tour of Downtown and Balboa Park\", \"productCode\": \"3871P10\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/0f/dd/e7/37.jpg\", \"description\": null, \"primaryCategory\": \"4WD, ATV & Off-Road Tours\"}]}", subtype: ["Zoos"], ratingHistogram: "{\"count1\": 235, \"count2\": 477, \"count3\": 1910, \"count4\": 5810, \"count5\": 21563}", location_contains_city: "True", id: "104122", longitude: "-117.14911", website: "http://zoo.sandiegozoo.org", rankingPosition: "3.0", address: "2929 Zoo Drive Balboa Park, San Diego, CA 92101", neighborhoodLocations: "[{\"id\": \"20484014\", \"name\": \"Balboa Park\"}]", rankingString: "#3 of 815 things to do in San Diego", City: "San Diego", localName: "San Diego Zoo", State: "California", webUrl: "https://www.tripadvisor.com/Attraction_Review-g60750-d104122-Reviews-San_Diego_Zoo-San_Diego_California.html", localAddress: "2929 Zoo Drive, Balboa Park, 92101", rankingDenominator: "815.0", name: "San Diego Zoo", locationString: "San Diego, California", subcategories: ["Zoos & Aquariums", "Nature & Parks", "Outdoor Activities"], rawRanking: "4.850902557", node_key: "Attraction::104122", source_kind: "mini_kg" };
