SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "2065", latitude: "32.772114", rating: "4.5", description: "Enjoy a slice of Californian life at this iconic long sandy beach in San Diego. This laidback beach town has almost two miles of beachfront boardwalk, lined with shops, bars, and restaurants. Here, you can cycle or rollerblade down the boardwalk, relax on the beach, go for a swim and surf, and even have fun at an amusement park. The old-school Belmont Park is free to enter and has both retro and modern amusement rides, food stalls, and entertainment all year round. There are also year-round whale-watching tours from Mission Bay, that'll take you to the best wildlife viewing spots.", visit_duration: "4.25", addressObj: "{\"street1\": \"3200 Ocean Front Walk\", \"street2\": \"Surfrider Square\", \"city\": \"San Diego\", \"state\": \"CA\", \"country\": \"United States\", \"postalcode\": \"92109\"}", offerGroup: "{\"lowestPrice\": \"$1.49\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FLa-Jolla%2FThe-Plunge-Bike-Tour%2Fd22636-5044P2%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=ad110b5ec6e605dca&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=104125&clt=TD&from=api&nt=true\", \"price\": \"$219.00\", \"roundedUpPrice\": \"$219\", \"offerType\": null, \"title\": \"The Summit To The Sea La Jolla Bike Tour\", \"productCode\": \"5044P2\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/0e/32/f2/ec.jpg\", \"description\": null, \"primaryCategory\": \"4WD, ATV & Off-Road Tours\"}, {\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FCarlsbad%2FBeachside-Moped-Rentals%2Fd23228-373260P2%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=51b6fa47723c39871&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=2&cnt=1&geo=104125&clt=TD&from=api&nt=true\", \"price\": \"$149.00\", \"roundedUpPrice\": \"$149\", \"offerType\": null, \"title\": \"Beachside Moped Rentals\", \"productCode\": \"373260P2\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/0f/e3/93/cb.jpg\", \"description\": null, \"primaryCategory\": \"Day Trips\"}]}", subtype: ["Beaches"], ratingHistogram: "{\"count1\": 22, \"count2\": 46, \"count3\": 190, \"count4\": 656, \"count5\": 1151}", location_contains_city: "True", id: "104125", longitude: "-117.25307", rankingPosition: "38.0", address: "3200 Ocean Front Walk Surfrider Square, San Diego, CA 92109", neighborhoodLocations: "[{\"id\": \"20484023\", \"name\": \"Pacific Beach\"}, {\"id\": \"21002011\", \"name\": \"Mission Beach\"}]", rankingString: "#38 of 815 things to do in San Diego", City: "San Diego", localName: "Mission Beach", State: "California", webUrl: "https://www.tripadvisor.com/Attraction_Review-g60750-d104125-Reviews-Mission_Beach-San_Diego_California.html", localAddress: "3200 Ocean Front Walk, Surfrider Square, 92109", rankingDenominator: "815.0", name: "Mission Beach", locationString: "San Diego, California", subcategories: ["Nature & Parks", "Outdoor Activities"], rawRanking: "3.89921689", node_key: "Attraction::104125", source_kind: "mini_kg" };
