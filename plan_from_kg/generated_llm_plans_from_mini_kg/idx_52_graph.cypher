SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "1979", latitude: "33.79003", rating: "4.5", description: "This stunning, porcelain-enameled building was designed by famed architect Richard Meier and is rivaled only by the art inside. Featuring American, European and African art, as well as decorative art and photography, the High Museum boasts a permanent collection of over 11,000 pieces, many of which can be viewed from different levels of the four-story, glass atrium.", visit_duration: "3.0", addressObj: "{\"street1\": \"1280 Peachtree St NE\", \"street2\": \"\", \"city\": \"Atlanta\", \"state\": \"GA\", \"country\": \"United States\", \"postalcode\": \"30309-3502\"}", offerGroup: "{\"lowestPrice\": \"$0.09\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FAtlanta%2FLocal-Tour-of-Heritage-and-Architectural-Buildings-in-Chennai%2Fd784-18568P50%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=5cb7d002f4b6c3705&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=144319&clt=TD&from=api&nt=true\", \"price\": \"$9.00\", \"roundedUpPrice\": \"$9\", \"offerType\": null, \"title\": \"Atlanta Self-Guided Audio Tour\", \"productCode\": \"18568P50\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/11/c6/f9/03.jpg\", \"description\": null, \"primaryCategory\": \"Cultural Tours\"}, {\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FAtlanta%2FAtlanta-101-Introduction-to-Atlanta%2Fd784-5510976P2%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=6ee3a1329da23297b&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=2&cnt=1&geo=144319&clt=TD&from=api&nt=true\", \"price\": \"$100.00\", \"roundedUpPrice\": \"$100\", \"offerType\": null, \"title\": \"Must See Sites of Atlanta Private City Tour\", \"productCod