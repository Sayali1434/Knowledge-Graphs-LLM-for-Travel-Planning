ocalName: "Max's Coal Oven Pizzeria", input: "Atlanta", phone: "+1 404-974-2941", State: "Georgia", webUrl: "https://www.tripadvisor.com/Restaurant_Review-g60898-d2257659-Reviews-Max_s_Coal_Oven_Pizzeria-Atlanta_Georgia.html", localAddress: "300 Marietta St NW, Marietta Street & BakerStreet, across from the Hilton Garden Inn Downtown, 30313-1632", `Rest-MidRange`: "90.0", name: "Max's Coal Oven Pizzeria", subcategories: ["Sit down"], rawRanking: "4.243808269500732", orderOnline: [], establishmentTypes: ["Restaurants"], isClaimedIcon: "True", latitude: "33.761597", menuWebUrl: "https://maxsatl.com/atlanta-downtown-atlanta-maxs-coal-oven-pizzeria-food-menu", description: "Since 2009, Max’s Coal Oven Pizzeria has been serving authentic New York-style pizza, classic salads, pasta, Italian sandwiches, signature coal oven wings, and freshly made desserts. A unique feature of our restaurant is that we have the ONLY GENUINE COAL OVEN IN GEORGIA, allowing us to create perfectly crisp pizzas with a unique taste and texture that has been a hallmark of New York City pizzerias for over a century. At Max's, we take great pride in our pizza. We've perfected our dough, topped it with our secret recipe red sauce, mozzarella, classic meats, and fresh vegetables. Max’s offers a variety of options to suit everyone's taste, from sausage and pepperoni to peppers and onions. Whether you want to watch the big game with friends, celebrate a birthday, or have a picnic in Centennial Olympic Park on a summer afternoon, Max’s is the perfect place to dine in or pick up simple and delicious Italian classics.", photoCount: "222.0", ratingHistogram: "{\"count1\": 19, \"count2\": 24, \"count3\": 81, \"count4\": 285, \"count5\": 400}", email: "maxsatl@lvmgt.com", website: "http://www.maxsatl.com", rankingPosition: "44.0", hours: "{\"weekRanges\": [[{\"open\": 660, \"openHours\": \"11:00\", \"close\": 1260, \"closeHours\": \"21:00\"}], [{\"open\": 660, \"openHours\": \"11:00\", \"close\": 1260, \"clos