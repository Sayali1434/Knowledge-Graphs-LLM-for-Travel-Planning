SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "1591", latitude: "33.760277", rating: "4.5", description: "Located in Downtown Atlanta, the College Football Hall of Fame and Chick-fil-A Fan Experience puts you closer to the game than ever before. From the huge helmet wall featuring over 760 schools in The Quad to the giant Indoor Playing Field and Chick-fil-A Peach Bowl Skill Zone, the College Football Hall of Fame provides fans of all ages with memorable things to do. Named one of the top 10 things to do in Atlanta, GA, the College Football Hall of Fame is the perfect spot to host an event. Whether you're looking to build company morale with a corporate team building event or want to plan a birthday party for the sports fan in your life, the College Football Hall of Fame has a variety of event spaces. Come visit us in Centennial Olympic Park and experience the essence of college football as told by hall of fame inductees, and be sure to check out the new exhibits and the fun events happening at the College Football Hall of Fame!", visit_duration: "3.0", addressObj: "{\"street1\": \"250 Marietta St NW\", \"street2\": \"\", \"city\": \"Atlanta\", \"state\": \"GA\", \"country\": \"United States\", \"postalcode\": \"30313-1602\"}", offerGroup: "{\"lowestPrice\": \"$0.09\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FAtlanta%2FAtlanta-CityPass%2Fd784-2640ATL%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=3ae0eb16017937810&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=7092286&clt=TD&from=api&nt=true\", \"price\": \"$102.25\", \"roundedUpPrice\": \"$103\", \"offerType\": null, \"title\": \"Atlanta CityPASS\\u00ae\", \"productCode\": \"2640ATL\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/0b/e6/ab/be.jpg\", \"description\": null, \"primaryCategory\": \"Sightsee