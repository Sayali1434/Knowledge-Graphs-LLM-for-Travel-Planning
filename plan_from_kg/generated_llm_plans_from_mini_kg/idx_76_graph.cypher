SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "836", latitude: "27.946356", rating: "4.5", description: "Since 1933, the Tampa Bay Hotel has been home to the Henry B. Plant Museum and The University of Tampa. The building, renamed Plant Hall, is a National Historic Landmark. The Henry B. Plant Museum holds the distinction of accreditation by the American Alliance of Museums. Its mission is to interpret the Tampa Bay Hotel and the experiences of the diverse individuals who contributed to its success. The Museum ignites thought and transports visitors to another era through exhibits and innovative programs, so that they may be educated and inspired by the lifestyles, times and experiences of Florida’s early tourist industry. Original furnishings and artifacts and a dynamic self-guided audio tour immerse visitors in the opulence of the 1891 Tampa Bay Hotel and its rich history.", visit_duration: "3.0", addressObj: "{\"street1\": \"401 W Kennedy Blvd\", \"street2\": \"\", \"city\": \"Tampa\", \"state\": \"FL\", \"country\": \"United States\", \"postalcode\": \"33606-1450\"}", offerGroup: "{\"lowestPrice\": \"$0.31\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FTampa%2FTampa-History-Cruise%2Fd666-10654P2%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=d7322c3e9fcc8b33e&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=109450&clt=TD&from=api&nt=true\", \"price\": \"$30.77\", \"roundedUpPrice\": \"$31\", \"offerType\": null, \"title\": \"Tampa History Cruise\", \"productCode\": \"10654P2\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/09/22/84/cc.jpg\", \"description\": null, \"primaryCategory\": \"Day Cruises\"}, {\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FTampa%2FTampa-Haunted-History-Guided-Walking-Tour%2Fd666-319796