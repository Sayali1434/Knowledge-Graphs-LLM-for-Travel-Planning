SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "630", latitude: "27.942371", rating: "4.5", description: "Set sail with explorers and pirates in the History Center's Treasure Seekers gallery, journey through the everglades with Florida Seminoles, ride along with a cattle drive, and roam the brick streets of Ybor City with immigrant cigar rollers. Located on the Tampa Riverwalk, the Tampa Bay History Center features three floors of interactive exhibits, theaters and displays, a museum store and waterfront dining at the Columbia Cafe.", visit_duration: "3.0", addressObj: "{\"street1\": \"801 Water Street\", \"street2\": \"\", \"city\": \"Tampa\", \"state\": \"FL\", \"country\": \"United States\", \"postalcode\": \"33602-5418\"}", subtype: ["History Museums"], ratingHistogram: "{\"count1\": 3, \"count2\": 14, \"count3\": 59, \"count4\": 205, \"count5\": 349}", location_contains_city: "True", id: "1963506", longitude: "-82.449875", website: "http://tampabayhistorycenter.org/", rankingPosition: "9.0", address: "801 Water Street, Tampa, FL 33602-5418", neighborhoodLocations: [], rankingString: "#9 of 378 things to do in Tampa", City: "Tampa", localName: "Tampa Bay History Center", State: "Florida", webUrl: "https://www.tripadvisor.com/Attraction_Review-g34678-d1963506-Reviews-Tampa_Bay_History_Center-Tampa_Florida.html", localAddress: "801 Water Street, 33602-5418", rankingDenominator: "378.0", name: "Tampa Bay History Center", locationString: "Tampa, Florida", subcategories: ["Museums"], rawRanking: "4.011276245", node_key: "Attraction::1963506", source_kind: "mini_kg" };
