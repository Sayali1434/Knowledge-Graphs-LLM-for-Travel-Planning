SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "253", latitude: "28.024601", rating: "5.0", description: "HorsePower for Kids is an outdoor animal sanctuary and family fun farm located in northwest Tampa near Oldsmar and Westchase. You can enjoy: Animal Petting Area, Pony rides, Playground, Tire & Bench Swings, Western Town and Tree House - No reservation is required while visiting during our business hours, you are welcome to tour the farm at your own leisure. We are open Thursday-Sunday. Closed during Summer Months (June/July/August)", visit_duration: "3.5", addressObj: "{\"street1\": \"8005 Race Track Rd\", \"street2\": \"\", \"city\": \"Tampa\", \"state\": \"FL\", \"country\": \"United States\", \"postalcode\": \"33635-9709\"}", subtype: ["Zoos", "Farms"], ratingHistogram: "{\"count1\": 4, \"count2\": 2, \"count3\": 4, \"count4\": 27, \"count5\": 216}", location_contains_city: "True", id: "2650465", longitude: "-82.64824", website: "http://www.horsepowerforkids.com", rankingPosition: "11.0", address: "8005 Race Track Rd, Tampa, FL 33635-9709", neighborhoodLocations: [], rankingString: "#11 of 378 things to do in Tampa", City: "Tampa", localName: "Horse Power for Kids & Animal Sanctuary", State: "Florida", webUrl: "https://www.tripadvisor.com/Attraction_Review-g34678-d2650465-Reviews-Horse_Power_for_Kids_Animal_Sanctuary-Tampa_Florida.html", localAddress: "8005 Race Track Rd, 33635-9709", rankingDenominator: "378.0", name: "Horse Power for Kids & Animal Sanctuary", locationString: "Tampa, Florida", subcategories: ["Sights & Landmarks", "Zoos & Aquariums", "Nature & Parks", "Outdoor Activities"], rawRanking: "3.999932051", node_key: "Attraction::2650465", source_kind: "mini_kg" };
