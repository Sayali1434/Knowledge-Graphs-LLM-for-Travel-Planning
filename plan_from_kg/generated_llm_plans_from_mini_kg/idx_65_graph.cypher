SET n += { nearestMetroStations: "[{\"name\": \"Seattle Center\", \"localName\": \"Seattle Center\", \"address\": \"305 Harrison St, Seattle, WA 98109\", \"localAddress\": \"305 Harrison St, 98109\", \"lines\": [{\"id\": \"seattle-monorail-monorail\", \"lineName\": \"Monorail\", \"lineSymbol\": \"https://static.tacdn.com/img/api/metro_stations/metro_placeholder.png\", \"systemName\": \"Monorail\", \"systemSymbol\": \"https://static.tacdn.com/img/api/metro_stations/metro_placeholder.png\", \"type\": \"Monorail\"}], \"latitude\": 47.622039794921875, \"longitude\": -122.35201263427734, \"distance\": 0.6326456613261846}]", localLangCode: "en-US", numberOfReviews: "3520", latitude: "47.62947", rating: "4.5", description: "Get a postcard view of downtown Seattle and Elliott Bay against the backdrop of snow-capped Mount Rainier from this beautiful terraced park. You'll also get spectacular views of the Space Needle, a 605-foot-tall observation tower. Take pictures and lounge or have a picnic on the lawn. The best time to visit is during sunrise, or at night to admire the buildings and ferries at the bay glow with lights. Though located in the quiet Queen Anne neighborhood, Kerry Park is less than a mile away from Seattle Center, where you can visit other landmarks like the Museum of Pop Culture. – Tripadvisor", visit_duration: "4.5", addressObj: "{\"street1\": \"211 W Highland Dr\", \"street2\": \"Queen Ann Hill\", \"city\": \"Seattle\", \"state\": \"WA\", \"country\": \"United States\", \"postalcode\": \"98119-3529\"}", offerGroup: "{\"lowestPrice\": \"$0.45\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FSeattle%2FSnoqualmie-Falls-and-Seattle-City-Tour%2Fd704-7265P1%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=0e9c925a0b5e54afa&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=1050677&clt=TD&from=api&nt=true\", \"price\": \"$89.00\", \"roundedUpPrice