SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "503", latitude: "35.224407", rating: "4.5", description: "Designed by Machado and Silvetti Associates of Boston, the five-story, 145,000-square-foot facility combines inspiring architecture with cutting-edge exhibitions to provide visitors with unparalleled educational and cultural experiences. Located in the heart of Charlotte's burgeoning city center, Mint Museum Uptown is an integral part of the Levine Center for the Arts, a cultural campus that includes the Bechtler Museum of Modern Art, the Harvey B. Gantt Center for African-American Arts and Culture, the Knight Theater, and the Duke Energy Center. Mint Museum Uptown also features a wide range of visitor amenities, including the 240-seat James B. Duke Auditorium, the Lewis Family Gallery, art studios, a restaurant, and a museum shop.", visit_duration: "3.0", addressObj: "{\"street1\": \"500 S Tryon St\", \"street2\": \"Levine Center for the Arts\", \"city\": \"Charlotte\", \"state\": \"NC\", \"country\": \"United States\", \"postalcode\": \"28202-1811\"}", offerGroup: "{\"lowestPrice\": \"$0.12\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FCharlotte%2FCharlottes-Historical-City-Tour%2Fd5284-55967P1%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=4ef2b5b2ea6eef910&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=2228276&clt=TD&from=api&nt=true\", \"price\": \"$39.00\", \"roundedUpPrice\": \"$39\", \"offerType\": null, \"title\": \"Charlotte's Premier Historical City Tour on Eco- Friendly Cart\", \"productCode\": \"55967P1\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/13/dd/28/2b.jpg\", \"description\": null, \"primaryCategory\": \"Historical & Heritage Tours\"}, {\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FCha