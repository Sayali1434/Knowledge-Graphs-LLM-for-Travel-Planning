SET n += { nearestMetroStations: "[{\"name\": \"Baltimore Penn Station\", \"localName\": \"Baltimore Penn Station\", \"address\": \"Baltimore, MD\", \"localAddress\": \"\", \"lines\": [], \"latitude\": 39.30738830566406, \"longitude\": -76.61566162109375, \"distance\": 0.7590756274557452}]", localLangCode: "en-US", numberOfReviews: "1487", latitude: "39.296432", rating: "5.0", description: "The Walters Art Museum is a cultural hub in the heart of Baltimore. Located in the city’s Mount Vernon neighborhood, the Walters is free for all. The museum’s collection spans more than seven millennia, from 5,000 BCE to the 21st century, and encompasses 36,000 objects from around the world. Walking through the museum’s historic buildings, visitors encounter a stunning panorama of thousands of years of art, from romantic 19th-century images of French gardens to mesmerizing Ethiopian icons, richly illuminated Qur’ans and Gospel books, ancient Roman sarcophagi, and serene images of the Buddha. The Walters' mission has been to bring art and people together and to create a place where people of every background can be touched by art. Admission to the museum and special exhibitions is always free.", visit_duration: "3.0", addressObj: "{\"street1\": \"600 N Charles St\", \"street2\": \"\", \"city\": \"Baltimore\", \"state\": \"MD\", \"country\": \"United States\", \"postalcode\": \"21201-5118\"}", offerGroup: "{\"lowestPrice\": \"$0.12\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FBaltimore%2FLets-Roams-Baltimore-Scavenger-Hunt-Monumental-Mount-Vernon%2Fd4375-104204P50%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=d1da8751e9fd861b9&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=103081&clt=TD&from=api&nt=true\", \"price\": \"$12.31\", \"roundedUpPrice\": \"$13\", \"offerType\": null, \"title\": \"Self-Guided Baltimore Scavenger Hunt: Monumental Mount Vernon\", \