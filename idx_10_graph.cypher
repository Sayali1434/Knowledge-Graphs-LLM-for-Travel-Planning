aran-Private-Tour-Baltimore-Harbor%2Fd4375-312442P2%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=43219c48844d32623&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=5&cnt=1&geo=109074&clt=TD&from=api&nt=true\", \"price\": \"$1,299.00\", \"roundedUpPrice\": \"$1,299\", \"offerType\": null, \"title\": \"Luxury Catamaran Private Tour Baltimore Harbor\", \"productCode\": \"312442P2\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/12/d3/5b/5e.jpg\", \"description\": null, \"primaryCategory\": \"Sailing Trips\"}]}", subtype: ["Neighborhoods", "Historic Walking Areas"], ratingHistogram: "{\"count1\": 9, \"count2\": 34, \"count3\": 197, \"count4\": 876, \"count5\": 1694}", location_contains_city: "True", id: "109074", longitude: "-76.588554", website: "http://baltimore.org/neighborhoods-maps-transportation/fells-point", rankingPosition: "10.0", address: "Fell St, Baltimore, MD 21231", neighborhoodLocations: "[{\"id\": \"20483762\", \"name\": \"Fells Point\"}]", rankingString: "#10 of 405 things to do in Baltimore", City: "Baltimore", localName: "Fell's Point", State: "Maryland", webUrl: "https://www.tripadvisor.com/Attraction_Review-g60811-d109074-Reviews-Fell_s_Point-Baltimore_Maryland.html", localAddress: "Fell St, 21231", rankingDenominator: "405.0", name: "Fell's Point", locationString: "Baltimore, Maryland", subcategories: ["Sights & Landmarks", "Other"], rawRanking: "4.082924366", node_key: "Attraction::109074", source_kind: "mini_kg" };
