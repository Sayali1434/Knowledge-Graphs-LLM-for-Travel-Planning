SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "1077", latitude: "39.26363", rating: "5.0", description: "The Sagamore Spirit Distillery is open Wednesday through Sunday for guided distillery tours and rye whiskey tastings. Located in the heart of Baltimore's Port Covington neighborhood with stunning waterfront views, Sagamore Spirit also offers a full calendar of indoor and outdoor events, including cocktail classes, glass blowing, and waterfront yoga. Sagamore Spirit is recognized internationally for their American Straight Rye Whiskies and is the recipient of over 100 awards for excellence in taste and packaging.", visit_duration: "2.5", addressObj: "{\"street1\": \"301 E Cromwell St\", \"street2\": null, \"city\": \"Baltimore\", \"state\": \"MD\", \"country\": \"United States\", \"postalcode\": \"21230-5012\"}", offerGroup: "{\"lowestPrice\": \"$9.75\", \"offerList\": [{\"url\": \"https://www.tripadvisor.com/Commerce?url=https%3A%2F%2Fwww.viator.com%2Ftours%2FBaltimore%2FPRIVATE-Local-Sunset-Sail-by-a-Certified-Captain%2Fd4375-363044P1%3Feap%3Dtripadvisor-main-11383%26aid%3Dtripen1&partnerKey=1&urlKey=2a47568702b83d912&logme=true&uidparam=refid&attrc=true&Provider=Viator&area=viator_multi&slot=1&cnt=1&geo=12093928&clt=TD&from=api&nt=true\", \"price\": \"$975.00\", \"roundedUpPrice\": \"$975\", \"offerType\": null, \"title\": \"PRIVATE Local Sunset Sail by a Certified Captain\", \"productCode\": \"363044P1\", \"partner\": \"Viator\", \"imageUrl\": \"https://media.tacdn.com/media/attractions-splice-spp-360x240/0f/85/f1/df.jpg\", \"description\": null, \"primaryCategory\": \"4WD, ATV & Off-Road Tours\"}]}", subtype: ["Distilleries"], ratingHistogram: "{\"count1\": 4, \"count2\": 1, \"count3\": 10, \"count4\": 70, \"count5\": 992}", location_contains_city: "True", id: "12093928", longitude: "-76.60631", website: "http://www.sagamorespirit.com", rankingPosition: "2.0", address: "301 E Cromwell St, Baltimore, MD 21230-5012", neighborhoodLocations: [], rankingString: "#2 of 405 things to do in Baltimore", City: "Baltimore", localName: "Sagamore Spirit Distillery", State: "Maryland", webUrl: "https://www.tripadvisor.com/Attraction_Review-g60811-d12093928-Reviews-Sagamore_Spirit_Distillery-Baltimore_Maryland.html", localAddress: "301 E Cromwell St, 21230-5012", rankingDenominator: "405.0", name: "Sagamore Spirit Distillery", locationString: "Baltimore, Maryland", subcategories: ["Food & Drink"], rawRanking: "4.343157768", node_key: "Attraction::12093928", source_kind: "mini_kg" };
MERGE (n:Attraction {node_key: "Attraction::144284"})
SET n += { nearestMetroStations: [], localLangCode: "en-US", numberOfReviews: "1651", latitude: "39.280437", rating: "4.5", description: "The American Visionary Art Museum is the nation's museum for self-taught, intuitive artistry. Three historic buildings house wonders created by farmers, housewives, mechanics, the disabled, the homeless, as well as the occasional neurosurgeon—all inspired by the fire within. From carved roots to embroidered rags, tattoos to toothpicks, ‘the visionary’ transforms dreams, loss, hopes, and ideals into powerful works of art. \"one of the most fantastic museums anywhere in America\" - CNN \"Best Museum in Maryland\" - USA Today \"a temple of outsider art\" - New York Times. Tickets: $9.95-15.95. Children 6 and under and museum members are free.", visit_duration: "3.0", addressObj: "{\"street1\": \"800 Key Hwy\", \"street2\": \"\", \"city\": \"Baltimore\", \"state\": \"MD\", \"country\": \"United States\", \"postalcode\": \"21230-3940\"}", subtype: ["Specialty Museums"], ratingHistogram: "{\"count1\": 22, \"count2\": 23, \"count3\": 88, \"count4\": 323, \"count5\": 1195}", location_contains_city: "True", id: "144284", longitude: "-76.606895", website: "http://www.avam.org", rankingPosition: "9.0", address: "800 Key Hwy, Baltimore, MD 21230-3940", neighborhoodLocations: "[{\"id\": \"20933746\", \"name\": \"Federal Hill\"}]", rankingString: "#9 of 405 things to do in Baltimore", City: "Baltimore", localName: "American Visionary Art Museum", State: "Maryland", webUrl: "https://www.tripadvisor.com/Attraction_Review-g60811-d144284-Reviews-American_Visionary_Art_Museum-Baltimore_Maryland.html", localAddress: "800 Key Hwy, 21230-3940", rankingDenominator: "405.0", name: "American Visionary Art Museum", locationString: "Baltimore, Maryland", subcategories: ["Museums"], rawRanking: "4.147795677", node_key: "Attraction::144284", source_kind: "mini_kg" };
